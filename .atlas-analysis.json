  "keyFeatures": [
    "StateGraph - Build stateful workflows with typed state",
    "MessageGraph - Specialized graphs for chat/message-based applications",
    "Checkpointing - Persist state with SQLite, Postgres, or custom savers",
    "Human-in-the-loop - Interrupt execution for human review and intervention",
    "Durable execution - Automatic recovery from failures with state persistence",
    "Streaming - Stream outputs in multiple modes (values, updates, messages)",
    "Multi-agent systems - Coordinate multiple agents with subgraphs",
    "Command API - Dynamic control flow with Send and Command",
    "Prebuilt components - Ready-to-use ReAct agents and tool nodes",
    "CLI tools - Development server, Docker deployment, and project scaffolding"
  ],
